# Email notification settings (optional – logs to console if not configured)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_FROM=your-email@gmail.com

# AI Assistant settings (optional)
# Default is rule_based, which is free and requires no API key.
# Use ollama for a free local LLM if Ollama is installed and running.
AI_PROVIDER=rule_based

# Ollama example (free local LLM)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2

# Optional hosted providers. Add your own key only if you want to use them.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
